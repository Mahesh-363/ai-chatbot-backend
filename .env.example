# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-min-50-chars-change-this
DEBUG=False
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=ai_chatbot
DB_USER=chatbot_user
DB_PASSWORD=your-strong-db-password
DB_HOST=postgres
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_RATE_LIMIT_URL=redis://redis:6379/1
REDIS_SESSION_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/3
CELERY_RESULT_BACKEND=redis://redis:6379/4

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30

# System prompt (optional override)
AI_SYSTEM_PROMPT=You are a helpful, harmless, and honest AI assistant.
AI_MAX_HISTORY_MESSAGES=20

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_CHAT_PER_MIN=20
RATE_LIMIT_CHAT_PER_HOUR=200
RATE_LIMIT_CHAT_PER_DAY=1000

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-frontend.com

# ── AWS (production) ──────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=ap-south-1
